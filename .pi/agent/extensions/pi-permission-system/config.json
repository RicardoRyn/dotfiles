{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": false,
  "toolInputPreviewMaxLength": 400,
  "toolTextSummaryMaxLength": 120,
  "piInfrastructureReadPaths": [],
  "permission": {
    "*": "ask",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "read": "allow",
    "write": {
      "*": "ask",
      "*.lock": "deny"
    },
    "edit": {
      "*": "ask",
      "*.lock": "deny"
    },
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "bash": {
      "git *": { "action": "deny", "reason": "Use jj instead" },
      "jj *": "ask",
      "jj status": "allow",
      "jj diff *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "sed *": "allow",
      "cat *": "allow"
    },
    "skill": { "*": "allow" },
    "external_directory": "allow",
    "memory_save": "allow",
    "memory_search": "allow",
    "codegraph_search": "allow",
    "codegraph_explore": "allow",
    "codegraph_node": "allow"
  }
}
