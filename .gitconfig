[user]
  name = Ricardo_MI_arch
  email = ricardoryn1317@gmail.com

[init]
  defaultBranch = main

# 分栏设置：自动在支持的终端中使用列式输出
[column]
  ui = auto

# 分支列表排序：按最近提交时间倒序显示
[branch]
  sort = -committerdate

# tag 列表排序方式：按版本号+引用名排序
[tag]
  sort = version:refname

[credential "https://gitee.com"]
  provider = generic
[credential "https://github.com"]
  helper = 
  helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
  helper = 
  helper = !/usr/bin/gh auth git-credential

[core]
  editor = nvim
  pager = delta

[diff]
  colorMoved = default
  oldMoved = bold purple
  newMoved = bold cyan

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true  # use n and N to move between diff sections
  line-numbers = true
  light = true      # or light = true, or omit for auto-detection
  map-styles = bold purple => syntax "#e5dff6", bold cyan => syntax "#d8fdf6"

[merge]
  conflictStyle = zdiff3
