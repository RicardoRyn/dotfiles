// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "context": "EmptyPane || vim_mode == normal",
        "bindings": {
            "space space": "file_finder::Toggle",
        },
    },
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            "j k": "vim::NormalBefore",
        },
    },
    {
        "context": "vim_mode == normal && !menu",
        "bindings": {
            "shift-y": ["workspace::SendKeystrokes", "y $"],
        },
    },
    {
        "context": "Dock",
        "bindings": {
            "ctrl-w h": "workspace::ActivatePaneLeft",
            "ctrl-w l": "workspace::ActivatePaneRight",
            "ctrl-w k": "workspace::ActivatePaneUp",
            "ctrl-w j": "workspace::ActivatePaneDown",
        },
    },
    {
        "context": "VimControl && !menu && vim_mode != operator",
        "bindings": {
            "w": "vim::NextSubwordStart",
            "b": "vim::PreviousSubwordStart",
            "e": "vim::NextSubwordEnd",
            "g e": "vim::PreviousSubwordEnd",
        },
    },
    // 接受ai建议
    {
        "context": "(Editor && edit_prediction)",
        "bindings": {
            "ctrl-y": "editor::AcceptEditPrediction",
        },
    },
    // 切换buffer
    {
        "context": "((VimControl && !menu) || (!Editor && !Terminal))",
        "bindings": {
            "shift-l": "vim::GoToTab"
        }
    },
    {
        "context": "((VimControl && !menu) || (!Editor && !Terminal))",
        "bindings": {
            "g t": null
        }
    },
    {
        "context": "((VimControl && !menu) || (!Editor && !Terminal))",
        "bindings": {
            "shift-h": "vim::GoToPreviousTab"
        }
    },
    {
        "context": "((VimControl && !menu) || (!Editor && !Terminal))",
        "bindings": {
            "g shift-t": null
        }
    },
    // 右dock/ai面板
    {
        "context": "EmptyPane || vim_mode == normal",
        "bindings": {
            "space a a": "workspace::ToggleRightDock"
        }
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-alt-b": null
        }
    },
    // 左dock/项目面板
    {
        "context": "EmptyPane || vim_mode == normal || (ProjectPanel && not_editing)",
        "bindings": {
            "space e": "workspace::ToggleLeftDock"
        }
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-b": null
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "space": null
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "r": "project_panel::Rename"
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "shift-r": null
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "o": null
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "o": "project_panel::Open"
        }
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "y": "project_panel::Copy"
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "p": null
        }
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "d": [
                "project_panel::Trash",
                {
                    "skip_prompt": false
                }
            ]
        }
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "p": "project_panel::Paste"
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "a": "project_panel::NewFile"
        }
    },
    {
        "context": "(ProjectPanel && not_editing)",
        "bindings": {
            "shift-x": "project_panel::RevealInFileManager"
        }
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "x": "project_panel::Cut"
        }
    },
    {
        "context": "Editor",
        "bindings": {
            "space l f": "editor::Format"
        }
    },
    {
        "context": "Editor",
        "unbind": {
            "alt-shift-f": "editor::Format"
        }
    },
    {
        "context": "Editor",
        "bindings": {
            "space l f": "editor::FormatSelections"
        }
    },
    {
        "context": "Editor",
        "unbind": {
            "ctrl-k ctrl-f": "editor::FormatSelections"
        }
    }
]
